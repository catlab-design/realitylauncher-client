---
/**
 * ========================================
 * index.astro - หน้าหลักของ App
 * ========================================
 *
 * หน้าแรกที่โหลดเมื่อเปิด Launcher
 * ใช้ LauncherApp component (React)
 */

import LauncherApp from "../components/LauncherApp";
import "../styles/global.css";
import rIcon from "../assets/r.svg";
---

<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="ML Client - Minecraft Launcher" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={rIcon.src} />

    <!-- Google Fonts - Prompt (Thai font) + Inter for title -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome Icons -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />

    <title>Reality - Minecraft Launcher</title>
  </head>
  <body class="bg-zinc-950">
    <!--
      client:only="react" - render เฉพาะ client side
      React component ไม่รัน SSR (ต้องใช้ window.api)
    -->
    <LauncherApp client:only="react" />
  </body>
</html>
