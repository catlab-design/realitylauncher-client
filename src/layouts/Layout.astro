---
/**
 * ========================================
 * Layout.astro - Layout หลักของ App
 * ========================================
 *
 * Layout component สำหรับ wrap หน้าต่างๆ
 *
 * Features:
 * - Import global CSS
 * - Meta tags
 * - Google Fonts (Inter)
 */

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="ML Client - Minecraft Launcher built with Astro + Electron"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/r.svg" />

    <!-- Google Fonts - Inter (modern, clean font) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <div class="app-container">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  /* Import global styles */
  @import "../styles/global.css";
</style>
