{
  "name": "reality-launcher",
  "private": true,
  "type": "module",
  "version": "3.0.2",
  "license": "GPL-3.0-only",
  "main": "dist-electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catlab-design/realitylauncher-client.git"
  },
  "bugs": {
    "url": "https://github.com/catlab-design/realitylauncher-client/issues"
  },
  "homepage": "https://github.com/catlab-design/realitylauncher-client#readme",
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  },
  "author": {
    "name": "Cat Lab_ Design",
    "email": "studiotne1@gmail.com"
  },
  "description": "A launcher for make you easier to play Minecraft",
  "scripts": {
    "dev": "bun run electron:build && concurrently --kill-others \"astro dev --port 4321 --strictPort\" \"wait-on tcp:4321 -i 200 && node scripts/run-electron.cjs .\"",
    "build": "astro build && bun run electron:build",
    "start": "node scripts/run-electron.cjs --force-prod .",
    "check:asar-writes": "node scripts/check-no-app-asar-writes.cjs",
    "check:release-workflow": "node scripts/check-release-workflow.cjs",
    "electron:build": "bun run check:asar-writes && esbuild src/electron/main.ts --bundle --platform=node --format=cjs --minify --external:electron --external:discord-rpc --external:electron-updater --external:minecraft-java-core --outfile=dist-electron/main.cjs && esbuild src/electron/preload.ts --bundle --platform=node --format=cjs --minify --external:electron --outdir=dist-electron",
    "dist": "bun run build && electron-builder",
    "dist:win": "bun run build && electron-builder --win",
    "dist:mac": "bun run build && electron-builder --mac",
    "dist:linux": "bun run build && electron-builder --linux",
    "dist:flatpak": "bun run build && electron-builder --linux flatpak --publish never",
    "dist:flatpak:fast": "electron-builder --linux flatpak --publish never",
    "dist:store": "node scripts/build-msixupload.cjs",
    "dist:store:fast": "SKIP_DIST_WIN=true node scripts/build-msixupload.cjs",
    "build:rust": "cd ./native && bun run build",
    "build:rust:cargo": "cd ./native && cargo build --release",
    "ci:check": "bun run check:asar-writes && bun run check:release-workflow && bun run build && cargo check --manifest-path native/Cargo.toml"
  },
  "build": {
    "appId": "net.catlab.reality-launcher",
    "productName": "Reality Launcher",
    "directories": {
      "output": "release-build"
    },
    "extraResources": [],
    "icon": "src/assets/r.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "native/index.cjs",
      "native/*.node"
    ],
    "asar": true,
    "asarUnpack": [
      "native/*.node"
    ],
    "compression": "normal",
    "win": {
      "icon": "src/assets/r.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.games",
      "extraResources": [
        {
          "from": "../ml-launcher-core/target/release",
          "to": "bin",
          "filter": [
            "ml-launcher-core"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Game",
      "extraResources": [
        {
          "from": "../ml-launcher-core/target/release",
          "to": "bin",
          "filter": [
            "ml-launcher-core"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "multiLanguageInstaller": true,
      "installerLanguages": [
        "th_TH",
        "en_US"
      ],
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "generic",
      "url": "https://cdn.reality.catlabdesign.space/client"
    }
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/react": "^4.4.2",
    "@fluentui/react-components": "^9.72.8",
    "@headlessui/react": "^2.2.9",
    "@tailwindcss/vite": "^4.1.18",
    "@types/adm-zip": "^0.5.7",
    "@types/discord-rpc": "^4.0.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "astro": "^5.16.5",
    "astro-electron": "^0.5.0",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.34.0",
    "fs-extra": "^11.3.3",
    "gsap": "^3.14.2",
    "iconv-lite": "^0.7.1",
    "minecraft-java-core": "^3.4.3",
    "pace-js": "^1.2.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "skinview3d": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "userland": "^0.4.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/iconv-lite": "^0.0.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.3"
  }
}
